<UserControl
    x:Class="zavod.UI.Modes.Projects.Screens.ProjectWorkCycleView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="Root" AutomationProperties.AutomationId="Projects.WorkCycle" ColumnSpacing="18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="WorkCycleChatColumn" Width="1.35*" />
            <ColumnDefinition x:Name="WorkCycleExecutionColumn" Width="1*" />
            <ColumnDefinition x:Name="WorkCycleResultColumn" Width="1*" />
        </Grid.ColumnDefinitions>

        <Border x:Name="ProjectInteractionSurface" Grid.Column="0" AutomationProperties.AutomationId="Projects.WorkCycle.Surface.Chat" Padding="20" Background="#232323" BorderBrush="#3A3A3A" BorderThickness="1" CornerRadius="16">
            <Grid RowSpacing="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Spacing="6">
                    <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="#F2F2F2" Text="Chat" />
                    <TextBlock x:Name="WorkCycleProjectContextText" FontFamily="Consolas" FontSize="12" Foreground="#9A9A9A" TextWrapping="Wrap" />
                    <TextBlock x:Name="WorkCycleChatSurfaceStateText" Foreground="#BEBEBE" TextWrapping="Wrap" />
                    <TextBlock x:Name="WorkCyclePhaseText" Foreground="#F2F2F2" TextWrapping="Wrap" />
                    <TextBlock x:Name="WorkCycleSummaryText" Foreground="#E4E4E4" TextWrapping="Wrap" />
                    <StackPanel x:Name="WorkCycleFocusBar" Orientation="Horizontal" Spacing="8">
                        <Button x:Name="WorkCycleFocusAutoButton" Content="Auto" />
                        <Button x:Name="WorkCycleFocusChatButton" Content="Chat" />
                        <Button x:Name="WorkCycleFocusExecutionButton" Content="Execution" />
                        <Button x:Name="WorkCycleFocusResultButton" Content="Result" />
                    </StackPanel>
                </StackPanel>

                <Border x:Name="WorkCycleProjectCard" Grid.Row="1" Padding="14" Background="#292929" BorderBrush="#3A3A3A" BorderThickness="1" CornerRadius="12">
                    <StackPanel Spacing="8">
                        <TextBlock FontSize="13" Foreground="#9A9A9A" Text="Project" />
                        <TextBlock x:Name="ProjectNameText" FontSize="18" FontWeight="SemiBold" Foreground="#F2F2F2" Text="-" />
                        <TextBlock FontSize="13" Foreground="#9A9A9A" Text="Project root" />
                        <TextBlock x:Name="ProjectRootText" FontFamily="Consolas" FontSize="13" Foreground="#DCDCDC" TextWrapping="Wrap" Text="-" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Padding="16" Background="#181818" BorderBrush="#303030" BorderThickness="1" CornerRadius="14">
                    <TextBlock x:Name="ProjectsDiscussionPreviewText" FontFamily="{StaticResource Ui.FontFamily.Projects.Regular}" FontSize="{StaticResource Ui.Typography.Projects.FontSize}" Foreground="#F2F2F2" TextWrapping="Wrap" />
                </Border>

                <Border x:Name="WorkCycleStateCard" Grid.Row="3" Padding="14" Background="#292929" BorderBrush="#3A3A3A" BorderThickness="1" CornerRadius="12">
                    <StackPanel Spacing="8">
                        <TextBlock FontSize="13" Foreground="#9A9A9A" Text="State" />
                        <TextBlock x:Name="EntryStateText" Foreground="#F2F2F2" Text="-" />
                        <TextBlock x:Name="StorageStateText" Foreground="#D0D0D0" TextWrapping="Wrap" Text="-" />
                        <TextBlock x:Name="ActiveShiftText" FontFamily="Consolas" Foreground="#F2F2F2" Text="-" />
                        <TextBlock x:Name="ActiveTaskText" FontFamily="Consolas" Foreground="#F2F2F2" Text="-" />
                        <TextBlock x:Name="WorkCycleChatSummaryTitleText" FontSize="16" FontWeight="SemiBold" Foreground="#F2F2F2" />
                        <TextBlock x:Name="WorkCycleChatSummaryText" Foreground="#E4E4E4" TextWrapping="Wrap" />
                        <TextBlock x:Name="WorkCycleChatSummaryNoteText" Foreground="#BEBEBE" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="4" Padding="14" Background="#292929" BorderBrush="#3A3A3A" BorderThickness="1" CornerRadius="12">
                    <StackPanel Spacing="10">
                        <Button x:Name="EnterWorkButton" HorizontalAlignment="Left" Content="Р’ СЂР°Р±РѕС‚Сѓ" Visibility="Collapsed" />
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="ProjectsComposerTextBox" PlaceholderText="РќР°РїРёС€РёС‚Рµ Р·Р°РґР°С‡Сѓ РёР»Рё РІРЅРµСЃРёС‚Рµ СѓС‚РѕС‡РЅРµРЅРёРµ" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="44" />
                            <Button x:Name="ProjectsComposerSendButton" Grid.Column="1" VerticalAlignment="Stretch" Content="РћС‚РїСЂР°РІРёС‚СЊ" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border x:Name="ProjectExecutionSurface" Grid.Column="1" Padding="20" Background="#232323" BorderBrush="#3A3A3A" BorderThickness="1" CornerRadius="16">
            <Grid RowSpacing="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Spacing="6">
                    <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="#F2F2F2" Text="Execution Surface" />
                    <TextBlock x:Name="WorkCycleExecutionSurfaceStateText" Foreground="#BEBEBE" TextWrapping="Wrap" />
                    <TextBlock x:Name="WorkCycleExecutionSummaryText" Foreground="#F2F2F2" TextWrapping="Wrap" />
                </StackPanel>

                <Border Grid.Row="1" Padding="14" Background="#292929" BorderBrush="#3A3A3A" BorderThickness="1" CornerRadius="12">
                    <Grid>
                        <StackPanel x:Name="ExecutionValidationPanel" Spacing="10" Visibility="Collapsed">
                            <TextBlock FontSize="13" Foreground="#9A9A9A" Text="Execution state" />
                            <TextBlock x:Name="ExecutionStateText" FontSize="18" FontWeight="SemiBold" Foreground="#F2F2F2" Text="Recovery hold" />
                            <TextBlock x:Name="ExecutionValidationReasonText" Foreground="#C8C8C8" TextWrapping="Wrap" />
                            <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#F2F2F2" Text="Validation" />
                            <Border Padding="12" Background="#1F1F1F" BorderBrush="#3A3A3A" BorderThickness="1" CornerRadius="10">
                                <TextBlock x:Name="ExecutionValidationSummaryText" Foreground="#F2F2F2" TextWrapping="Wrap" />
                            </Border>
                            <Border Padding="12" Background="#1F1F1F" BorderBrush="#3A3A3A" BorderThickness="1" CornerRadius="10">
                                <TextBlock x:Name="ExecutionValidationItemsText" Foreground="#E4E4E4" TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>

                        <StackPanel x:Name="ExecutionRuntimePanel" Spacing="8">
                            <TextBlock FontSize="13" Foreground="#9A9A9A" Text="Execution state" />
                            <TextBlock x:Name="ExecutionRuntimeStateText" FontSize="18" FontWeight="SemiBold" Foreground="#F2F2F2" Text="Recovery hold" />
                            <TextBlock x:Name="ExecutionDetailText" Foreground="#C8C8C8" TextWrapping="Wrap" Text="This surface is reserved and visible again, but no live execution controls are wired back yet." />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Padding="14" Background="#292929" BorderBrush="#3A3A3A" BorderThickness="1" CornerRadius="12">
                    <Grid>
                        <StackPanel x:Name="ExecutionValidationActionsPanel" Orientation="Horizontal" Spacing="8" Visibility="Collapsed">
                            <Button x:Name="ExecutionConfirmButton" Content="РџРѕРґС‚РІРµСЂРґРёС‚СЊ" />
                            <Button x:Name="ExecutionClarifyButton" Content="РСЃРїСЂР°РІРёС‚СЊ" />
                            <Button x:Name="ExecutionReturnToChatButton" Content="Р’РµСЂРЅСѓС‚СЊСЃСЏ РІ С‡Р°С‚" />
                        </StackPanel>

                        <StackPanel x:Name="ExecutionClarificationPanel" Margin="0,44,0,0" Spacing="8" Visibility="Collapsed">
                            <TextBox x:Name="ExecutionClarificationTextBox" PlaceholderText="РћРїРёС€РёС‚Рµ, С‡С‚Рѕ РЅСѓР¶РЅРѕ СѓС‚РѕС‡РЅРёС‚СЊ" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="60" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button x:Name="ExecutionApplyClarificationButton" Content="РџСЂРёРјРµРЅРёС‚СЊ СѓС‚РѕС‡РЅРµРЅРёРµ" />
                                <Button x:Name="ExecutionCancelClarificationButton" Content="РћС‚РјРµРЅР°" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel x:Name="ExecutionRuntimeDetailsPanel" Spacing="10">
                            <TextBlock FontSize="13" Foreground="#9A9A9A" Text="Available evidence" />
                            <TextBlock x:Name="DocumentStageText" Foreground="#F2F2F2" Text="-" TextWrapping="Wrap" />
                            <TextBlock x:Name="ProjectDocumentPathText" FontFamily="Consolas" FontSize="13" Foreground="#B8B8B8" TextWrapping="Wrap" Text="-" />
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Button x:Name="OpenProjectDocumentButton" Content="Open project doc" />
                                <Button x:Name="OpenCapsuleDocumentButton" Content="Open capsule doc" />
                            </StackPanel>
                            <StackPanel x:Name="ExecutionActionStubBar" Orientation="Horizontal" Spacing="8">
                                <Button x:Name="ExecutionConfirmStubButton" Content="Confirm" IsEnabled="False" />
                                <Button x:Name="ExecutionClarifyStubButton" Content="Clarify" IsEnabled="False" />
                                <Button x:Name="ExecutionCancelStubButton" Content="Pause/Cancel" IsEnabled="False" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border x:Name="ProjectResultSurface" Grid.Column="2" Padding="20" Background="#232323" BorderBrush="#3A3A3A" BorderThickness="1" CornerRadius="16">
            <Grid RowSpacing="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Spacing="6">
                    <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="#F2F2F2" Text="Result Surface" />
                    <TextBlock x:Name="WorkCycleResultSurfaceStateText" Foreground="#BEBEBE" TextWrapping="Wrap" />
                    <TextBlock x:Name="WorkCycleResultSummaryText" Foreground="#F2F2F2" TextWrapping="Wrap" />
                </StackPanel>

                <Border Grid.Row="1" Padding="14" Background="#292929" BorderBrush="#3A3A3A" BorderThickness="1" CornerRadius="12">
                    <StackPanel Spacing="8">
                        <TextBlock FontSize="13" Foreground="#9A9A9A" Text="Result state" />
                        <TextBlock x:Name="ResultStateText" FontSize="18" FontWeight="SemiBold" Foreground="#F2F2F2" Text="No result loaded" />
                        <TextBlock x:Name="ResultDetailText" Foreground="#C8C8C8" TextWrapping="Wrap" Text="Result lifecycle stays disconnected until discussion and execution layers are safely restored." />
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Padding="14" Background="#292929" BorderBrush="#3A3A3A" BorderThickness="1" CornerRadius="12">
                    <StackPanel Spacing="10">
                        <TextBlock x:Name="WorkCycleResultMetadataText" Foreground="#E4E4E4" TextWrapping="Wrap" />
                        <StackPanel x:Name="ResultActionStubBar" Orientation="Horizontal" Spacing="8">
                            <Button x:Name="ResultAcceptStubButton" Content="Accept" IsEnabled="False" />
                            <Button x:Name="ResultReviseStubButton" Content="Revise" IsEnabled="False" />
                            <Button x:Name="ResultRejectStubButton" Content="Reject" IsEnabled="False" />
                        </StackPanel>
                        <TextBlock FontSize="13" Foreground="#9A9A9A" Text="What was intentionally withheld" />
                        <TextBlock x:Name="ResultNotesText" Foreground="#C8C8C8" TextWrapping="Wrap" Text="Chat timeline, execution controls, QC/result actions, and the new UI flow remain off until each layer is reintroduced under verification." />
                        <Button x:Name="ReturnToExecutionSurfaceButton" HorizontalAlignment="Left" Content="Return to execution" Visibility="Collapsed" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
