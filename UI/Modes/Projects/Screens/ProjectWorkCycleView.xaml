<UserControl
    x:Class="zavod.UI.Modes.Projects.Screens.ProjectWorkCycleView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:chats="using:zavod.UI.Modes.Chats"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="Root" AutomationProperties.AutomationId="Projects.WorkCycle" ColumnSpacing="18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="WorkCycleChatColumn" Width="1.35*" />
            <ColumnDefinition x:Name="WorkCycleExecutionColumn" Width="1*" />
            <ColumnDefinition x:Name="WorkCycleResultColumn" Width="1*" />
        </Grid.ColumnDefinitions>

        <Border x:Name="ProjectInteractionSurface" Grid.Column="0" AutomationProperties.AutomationId="Projects.WorkCycle.Surface.Chat" Padding="20" Background="#232323" BorderBrush="#3A3A3A" BorderThickness="1" CornerRadius="16">
            <Grid RowSpacing="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Spacing="6">
                    <TextBlock x:Name="ChatTitleText" FontSize="22" FontWeight="SemiBold" Foreground="#F2F2F2" />
                    <TextBlock x:Name="WorkCycleProjectContextText" FontFamily="Consolas" FontSize="12" Foreground="#9A9A9A" TextWrapping="Wrap" />
                    <TextBlock x:Name="WorkCycleChatSurfaceStateText" Foreground="#BEBEBE" TextWrapping="Wrap" />
                    <TextBlock x:Name="WorkCyclePhaseText" Foreground="#F2F2F2" TextWrapping="Wrap" />
                    <TextBlock x:Name="WorkCycleSummaryText" Foreground="#E4E4E4" TextWrapping="Wrap" />
                    <StackPanel x:Name="WorkCycleFocusBar" Orientation="Horizontal" Spacing="8">
                        <Button x:Name="WorkCycleFocusAutoButton" />
                        <Button x:Name="WorkCycleFocusChatButton" />
                        <Button x:Name="WorkCycleFocusExecutionButton" />
                        <Button x:Name="WorkCycleFocusResultButton" />
                    </StackPanel>
                </StackPanel>

                <Border x:Name="WorkCycleProjectCard" Grid.Row="1" Padding="14" Background="#292929" BorderBrush="#3A3A3A" BorderThickness="1" CornerRadius="12">
                    <StackPanel Spacing="8">
                        <TextBlock x:Name="ProjectTitleText" FontSize="13" Foreground="#9A9A9A" />
                        <TextBlock x:Name="ProjectNameText" FontSize="18" FontWeight="SemiBold" Foreground="#F2F2F2" Text="-" />
                        <TextBlock x:Name="ProjectRootTitleText" FontSize="13" Foreground="#9A9A9A" />
                        <TextBlock x:Name="ProjectRootText" FontFamily="Consolas" FontSize="13" Foreground="#DCDCDC" TextWrapping="Wrap" Text="-" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Padding="0" Background="#181818" BorderBrush="#303030" BorderThickness="1" CornerRadius="14">
                    <chats:ChatsWebRendererView x:Name="ProjectsConversationRenderer" />
                </Border>

                <Border x:Name="WorkCycleStateCard" Grid.Row="3" Padding="14" Background="#292929" BorderBrush="#3A3A3A" BorderThickness="1" CornerRadius="12">
                    <StackPanel Spacing="8">
                        <TextBlock x:Name="StateTitleText" FontSize="13" Foreground="#9A9A9A" />
                        <TextBlock x:Name="EntryStateText" Foreground="#F2F2F2" Text="-" />
                        <TextBlock x:Name="StorageStateText" Foreground="#D0D0D0" TextWrapping="Wrap" Text="-" />
                        <TextBlock x:Name="ActiveShiftText" FontFamily="Consolas" Foreground="#F2F2F2" Text="-" />
                        <TextBlock x:Name="ActiveTaskText" FontFamily="Consolas" Foreground="#F2F2F2" Text="-" />
                        <TextBlock x:Name="WorkCycleChatSummaryTitleText" FontSize="16" FontWeight="SemiBold" Foreground="#F2F2F2" />
                        <TextBlock x:Name="WorkCycleChatSummaryText" Foreground="#E4E4E4" TextWrapping="Wrap" />
                        <TextBlock x:Name="WorkCycleChatSummaryNoteText" Foreground="#BEBEBE" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="4" Padding="14" Background="#292929" BorderBrush="#3A3A3A" BorderThickness="1" CornerRadius="12">
                    <StackPanel Spacing="10">
                        <Button x:Name="EnterWorkButton" HorizontalAlignment="Left" Visibility="Collapsed" />
                        <Grid x:Name="ProjectsComposerGrid" ColumnSpacing="10" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="ProjectsComposerTextBox" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="44" />
                            <Button x:Name="ProjectsComposerSendButton" Grid.Column="1" VerticalAlignment="Stretch" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border x:Name="ProjectExecutionSurface" Grid.Column="1" Padding="20" Background="#232323" BorderBrush="#3A3A3A" BorderThickness="1" CornerRadius="16">
            <Grid RowSpacing="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Spacing="6">
                    <TextBlock x:Name="ExecutionTitleText" FontSize="22" FontWeight="SemiBold" Foreground="#F2F2F2" />
                    <TextBlock x:Name="WorkCycleExecutionSurfaceStateText" Foreground="#BEBEBE" TextWrapping="Wrap" />
                    <TextBlock x:Name="WorkCycleExecutionSummaryText" Foreground="#F2F2F2" TextWrapping="Wrap" />
                </StackPanel>

                <Border Grid.Row="1" Padding="14" Background="#292929" BorderBrush="#3A3A3A" BorderThickness="1" CornerRadius="12">
                    <Grid>
                        <StackPanel x:Name="ExecutionValidationPanel" Spacing="10" Visibility="Collapsed">
                            <TextBlock x:Name="ExecutionStateTitleText" FontSize="13" Foreground="#9A9A9A" />
                            <TextBlock x:Name="ExecutionStateText" FontSize="18" FontWeight="SemiBold" Foreground="#F2F2F2" />
                            <TextBlock x:Name="ExecutionValidationReasonText" Foreground="#C8C8C8" TextWrapping="Wrap" />
                            <TextBlock x:Name="ValidationTitleText" FontSize="16" FontWeight="SemiBold" Foreground="#F2F2F2" />
                            <Border Padding="12" Background="#1F1F1F" BorderBrush="#3A3A3A" BorderThickness="1" CornerRadius="10">
                                <TextBlock x:Name="ExecutionValidationSummaryText" Foreground="#F2F2F2" TextWrapping="Wrap" />
                            </Border>
                            <Border Padding="12" Background="#1F1F1F" BorderBrush="#3A3A3A" BorderThickness="1" CornerRadius="10">
                                <TextBlock x:Name="ExecutionValidationItemsText" Foreground="#E4E4E4" TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>

                        <StackPanel x:Name="ExecutionRuntimePanel" Spacing="8">
                            <TextBlock x:Name="ExecutionRuntimeStateTitleText" FontSize="13" Foreground="#9A9A9A" />
                            <TextBlock x:Name="ExecutionRuntimeStateText" FontSize="18" FontWeight="SemiBold" Foreground="#F2F2F2" />
                            <TextBlock x:Name="ExecutionDetailText" Foreground="#C8C8C8" TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Padding="14" Background="#292929" BorderBrush="#3A3A3A" BorderThickness="1" CornerRadius="12">
                    <Grid>
                        <StackPanel x:Name="ExecutionValidationActionsPanel" Orientation="Horizontal" Spacing="8" Visibility="Collapsed">
                            <Button x:Name="ExecutionConfirmButton" />
                            <Button x:Name="ExecutionClarifyButton" />
                            <Button x:Name="ExecutionReturnToChatButton" />
                        </StackPanel>

                        <StackPanel x:Name="ExecutionClarificationPanel" Margin="0,44,0,0" Spacing="8" Visibility="Collapsed">
                            <TextBox x:Name="ExecutionClarificationTextBox" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="60" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button x:Name="ExecutionApplyClarificationButton" />
                                <Button x:Name="ExecutionCancelClarificationButton" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel x:Name="ExecutionRuntimeDetailsPanel" Spacing="10">
                            <TextBlock x:Name="AvailableEvidenceTitleText" FontSize="13" Foreground="#9A9A9A" />
                            <TextBlock x:Name="DocumentStageText" Foreground="#F2F2F2" Text="-" TextWrapping="Wrap" />
                            <TextBlock x:Name="ProjectDocumentPathText" FontFamily="Consolas" FontSize="13" Foreground="#B8B8B8" TextWrapping="Wrap" Text="-" />
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Button x:Name="OpenProjectDocumentButton" />
                                <Button x:Name="OpenCapsuleDocumentButton" />
                            </StackPanel>
                            <StackPanel x:Name="ExecutionActionStubBar" Orientation="Horizontal" Spacing="8">
                                <Button x:Name="ExecutionConfirmStubButton" IsEnabled="False" />
                                <Button x:Name="ExecutionClarifyStubButton" IsEnabled="False" />
                                <Button x:Name="ExecutionCancelStubButton" IsEnabled="False" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border x:Name="ProjectResultSurface" Grid.Column="2" Padding="20" Background="#232323" BorderBrush="#3A3A3A" BorderThickness="1" CornerRadius="16">
            <Grid RowSpacing="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Spacing="6">
                    <TextBlock x:Name="ResultTitleText" FontSize="22" FontWeight="SemiBold" Foreground="#F2F2F2" />
                    <TextBlock x:Name="WorkCycleResultSurfaceStateText" Foreground="#BEBEBE" TextWrapping="Wrap" />
                    <TextBlock x:Name="WorkCycleResultSummaryText" Foreground="#F2F2F2" TextWrapping="Wrap" />
                </StackPanel>

                <Border Grid.Row="1" Padding="14" Background="#292929" BorderBrush="#3A3A3A" BorderThickness="1" CornerRadius="12">
                    <StackPanel Spacing="8">
                        <TextBlock x:Name="ResultStateTitleText" FontSize="13" Foreground="#9A9A9A" />
                        <TextBlock x:Name="ResultStateText" FontSize="18" FontWeight="SemiBold" Foreground="#F2F2F2" />
                        <TextBlock x:Name="ResultDetailText" Foreground="#C8C8C8" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Padding="14" Background="#292929" BorderBrush="#3A3A3A" BorderThickness="1" CornerRadius="12">
                    <StackPanel Spacing="10">
                        <TextBlock x:Name="WorkCycleResultMetadataText" Foreground="#E4E4E4" TextWrapping="Wrap" />
                        <StackPanel x:Name="ResultActionStubBar" Orientation="Horizontal" Spacing="8">
                            <Button x:Name="ResultAcceptStubButton" IsEnabled="False" />
                            <Button x:Name="ResultReviseStubButton" IsEnabled="False" />
                            <Button x:Name="ResultRejectStubButton" IsEnabled="False" />
                        </StackPanel>
                        <TextBlock x:Name="WithheldTitleText" FontSize="13" Foreground="#9A9A9A" />
                        <TextBlock x:Name="ResultNotesText" Foreground="#C8C8C8" TextWrapping="Wrap" />
                        <Button x:Name="ReturnToExecutionSurfaceButton" HorizontalAlignment="Left" Visibility="Collapsed" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
