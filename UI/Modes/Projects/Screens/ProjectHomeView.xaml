<UserControl
    x:Class="zavod.UI.Modes.Projects.Screens.ProjectHomeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="Root" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="8">
            <TextBlock Text="Project Home" FontSize="28" FontWeight="SemiBold" Foreground="#F2F2F2" />
            <TextBlock x:Name="SummaryText" Foreground="#E4E4E4" TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button x:Name="OpenProjectHtmlButton" Content="Open HTML" />
                <Button x:Name="OpenProjectDocumentButton" Content="Open project doc" />
                <Button x:Name="OpenWorkCycleButton" AutomationProperties.AutomationId="Projects.Home.OpenWorkCycle" Content="Open work cycle" />
            </StackPanel>
        </StackPanel>

        <Grid Grid.Row="1" ColumnSpacing="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*" />
                <ColumnDefinition Width="1.2*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Padding="18" Background="#1F1F1F" BorderBrush="#363636" BorderThickness="1" CornerRadius="16">
                <StackPanel Spacing="10">
                    <TextBlock Text="Overview" FontSize="18" FontWeight="SemiBold" Foreground="#F2F2F2" />
                    <TextBlock x:Name="StatusText" Foreground="#F2F2F2" TextWrapping="Wrap" />
                    <TextBlock x:Name="StageText" Foreground="#E4E4E4" TextWrapping="Wrap" />
                    <TextBlock x:Name="ActivityText" Foreground="#E4E4E4" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Padding="18" Background="#1F1F1F" BorderBrush="#363636" BorderThickness="1" CornerRadius="16">
                <StackPanel Spacing="10">
                    <TextBlock Text="Materials" FontSize="18" FontWeight="SemiBold" Foreground="#F2F2F2" />
                    <TextBlock x:Name="MaterialsText" Foreground="#F2F2F2" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Padding="18" Background="#1F1F1F" BorderBrush="#363636" BorderThickness="1" CornerRadius="16">
            <TextBlock x:Name="NotesText" Foreground="#E4E4E4" TextWrapping="Wrap" />
        </Border>
    </Grid>
</UserControl>
