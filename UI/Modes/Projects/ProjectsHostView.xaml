<UserControl
    x:Class="zavod.UI.Modes.Projects.ProjectsHostView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:screens="using:zavod.UI.Modes.Projects.Screens"
    mc:Ignorable="d">

    <Grid x:Name="Root" Margin="18" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="12" Background="#1D1D1D" BorderBrush="#323232" BorderThickness="1" CornerRadius="16">
            <StackPanel Spacing="6">
                <TextBlock x:Name="ScreenTitleText" Text="Projects" FontSize="24" FontWeight="SemiBold" Foreground="#F2F2F2" />
                <TextBlock x:Name="ModeSummaryText" Foreground="#E4E4E4" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <screens:ProjectListView x:Name="ProjectListView" />
            <screens:ProjectHomeView x:Name="ProjectHomeView" Visibility="Collapsed" />
            <screens:ProjectWorkCycleView x:Name="ProjectWorkCycleView" Visibility="Collapsed" />
        </Grid>
    </Grid>
</UserControl>
