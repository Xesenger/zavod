<UserControl
    x:Class="zavod.UI.Modes.Chats.ChatsHostView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conversation="using:zavod.UI.Rendering.Conversation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid
        x:Name="ChatsModeRoot"
        Background="{StaticResource Ui.Chat.BackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="ChatsSidebarColumn" Width="270" />
            <ColumnDefinition Width="1" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid
            x:Name="ChatsSidebarCard"
            Grid.Column="0"
            Padding="20,82,12,120"
            Background="Transparent">
            <StackPanel Spacing="2">
                <Button
                    x:Name="ChatsNewChatButton"
                    AutomationProperties.AutomationId="Chats.NewChat"
                    Style="{StaticResource ChatsSidebarNewChatButtonStyle}"
                    Click="ChatsNewChatButton_Click"
                    Content="+  &#x041D;&#x043E;&#x0432;&#x044B;&#x0439; &#x0447;&#x0430;&#x0442;" />

                <StackPanel
                    x:Name="ChatsListPanel"
                    Margin="0,6,0,0"
                    Spacing="2" />

                <TextBlock
                    x:Name="ChatsSidebarNoteText"
                    Visibility="Collapsed" />
            </StackPanel>
        </Grid>

        <Grid
            x:Name="ChatsDivider"
            Grid.Column="1"
            Width="1"
            Margin="0,32,0,40"
            Background="{StaticResource Ui.Chat.DividerBrush}" />

        <Grid
            Grid.Column="2"
            Padding="48,72,48,36">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel
                x:Name="ChatsSummaryHost"
                Grid.Row="0"
                MaxWidth="{StaticResource Ui.Layout.Chats.RailMaxWidth}"
                HorizontalAlignment="Center"
                Margin="0"
                Spacing="4"
                Visibility="Collapsed">
                <TextBlock
                    Text="Chats"
                    FontFamily="{StaticResource Ui.FontFamily.Chrome.SemiBold}"
                    FontSize="12"
                    Foreground="{StaticResource Ui.Chat.TextSecondaryBrush}"
                    Opacity="0.88" />
                <TextBlock
                    x:Name="ChatsSummaryText"
                    FontFamily="{StaticResource Ui.FontFamily.Chrome.Regular}"
                    FontSize="12"
                    Foreground="{StaticResource Ui.Chat.TextSecondaryBrush}"
                    Opacity="0.88"
                    TextWrapping="Wrap" />
            </StackPanel>

            <Grid Grid.Row="1">
                <StackPanel
                    x:Name="ChatsEmptyStatePanel"
                    AutomationProperties.AutomationId="Chats.EmptyState"
                    MaxWidth="420"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="0,0,0,88"
                    Spacing="14"
                    Visibility="Collapsed">
                    <StackPanel
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Spacing="10"
                        Margin="0,0,0,2">
                        <Rectangle Width="52" Height="1" Fill="{StaticResource Ui.Chat.DividerBrush}" />
                        <Ellipse Width="5" Height="5" Fill="{StaticResource Ui.Chat.DividerBrush}" />
                        <Rectangle Width="52" Height="1" Fill="{StaticResource Ui.Chat.DividerBrush}" />
                    </StackPanel>
                    <TextBlock
                        x:Name="ChatsEmptyHeadlineText"
                        HorizontalAlignment="Center"
                        FontFamily="{StaticResource Ui.FontFamily.Chats.SemiBold}"
                        FontSize="30"
                        Foreground="{StaticResource Ui.Chat.TextPrimaryBrush}"
                        Text="Ready when you are." />
                    <TextBlock
                        x:Name="ChatsEmptySubtitleText"
                        HorizontalAlignment="Center"
                        FontFamily="{StaticResource Ui.FontFamily.Chats.Regular}"
                        FontSize="15"
                        Foreground="{StaticResource Ui.Chat.TextPrimaryBrush}"
                        TextAlignment="Center"
                        TextWrapping="Wrap" />
                </StackPanel>

                <Border
                    x:Name="ChatsConversationCard"
                    AutomationProperties.AutomationId="Chats.ConversationRail"
                    Width="{StaticResource Ui.Layout.Chats.RailMaxWidth}"
                    MaxWidth="{StaticResource Ui.Layout.Chats.RailMaxWidth}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Stretch"
                    Padding="0"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    CornerRadius="0">
                    <conversation:ConversationView x:Name="ChatsConversationView" />
                </Border>
            </Grid>

            <Border
                x:Name="ChatsComposerHost"
                AutomationProperties.AutomationId="Chats.ComposerHost"
                Grid.Row="2"
                Width="{StaticResource Ui.Layout.Chats.RailMaxWidth}"
                MaxWidth="{StaticResource Ui.Layout.Chats.RailMaxWidth}"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,24,0,8"
                Background="Transparent">
                <Grid
                    x:Name="ChatsComposerCard"
                    HorizontalAlignment="Stretch"
                    MinHeight="44"
                    ColumnSpacing="0"
                    RowSpacing="0"
                    Background="Transparent">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Rectangle
                        Grid.Column="0"
                        Grid.ColumnSpan="3"
                        Height="1"
                        VerticalAlignment="Bottom"
                        Fill="{StaticResource Ui.Chat.DividerBrush}" />

                    <TextBox
                        x:Name="ChatsComposerTextBox"
                        Grid.Column="0"
                        Grid.ColumnSpan="3"
                        Style="{StaticResource ChatsComposerTextBoxStyle}"
                        MinHeight="44"
                        VerticalAlignment="Stretch"
                        Foreground="{StaticResource Ui.Chat.TextPrimaryBrush}"
                        PlaceholderForeground="{StaticResource Ui.Chat.TextSecondaryBrush}"
                        FontFamily="{StaticResource Ui.FontFamily.Chats.Regular}"
                        FontSize="{StaticResource Ui.Typography.Chats.Composer.FontSize}"
                        PlaceholderText="&#x041D;&#x0430;&#x0447;&#x043D;&#x0438; &#x043C;&#x044B;&#x0441;&#x043B;&#x044C;..."
                        TextWrapping="NoWrap"
                        AcceptsReturn="False" />

                    <Button
                        x:Name="ChatsComposerAttachButton"
                        Grid.Column="0"
                        AutomationProperties.AutomationId="Chats.Composer.Attach"
                        Style="{StaticResource ChatsIconButtonStyle}"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        ContentTemplate="{x:Null}"
                        IsEnabled="True" />

                    <TextBlock
                        x:Name="ChatsPersistenceText"
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource Ui.FontFamily.Chrome.Regular}"
                        FontSize="14"
                        Foreground="{StaticResource Ui.Chat.TextSecondaryBrush}"
                        Visibility="Collapsed"
                        TextWrapping="Wrap" />

                    <Button
                        x:Name="ChatsComposerSendButton"
                        Grid.Column="2"
                        AutomationProperties.AutomationId="ChatsComposerSendButton"
                        Style="{StaticResource ChatsIconButtonStyle}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Click="ChatsComposerSendButton_Click"
                        ContentTemplate="{x:Null}" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
