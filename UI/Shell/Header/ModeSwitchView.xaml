<UserControl
    x:Class="zavod.UI.Shell.Header.ModeSwitchView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border
        x:Name="ModeSwitchBorder"
        Width="292"
        Height="40"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        Padding="4"
        Background="{StaticResource Ui.Chat.ChromeSurfaceBrush}"
        BorderBrush="{StaticResource Ui.Chat.ChromeBorderBrush}"
        BorderThickness="1"
        CornerRadius="{StaticResource Ui.CornerRadius.Xl}">
        <Grid ColumnSpacing="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button
                x:Name="ChatsModeButton"
                Grid.Column="0"
                Style="{StaticResource ModeSwitchSegmentButtonStyle}"
                Click="ChatsModeButton_Click"
                Content="Chats" />
            <Button
                x:Name="ProjectsModeButton"
                Grid.Column="1"
                Style="{StaticResource ModeSwitchSegmentButtonStyle}"
                Click="ProjectsModeButton_Click"
                Content="Projects" />
        </Grid>
    </Border>
</UserControl>
