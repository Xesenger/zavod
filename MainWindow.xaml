<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="zavod.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="WindowRoot" Background="#171717">
        <Grid RowSpacing="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border
                x:Name="HeaderBorder"
                Grid.Row="0"
                Margin="18,18,18,0"
                Padding="14,12,14,12"
                Background="#1D1D1D"
                BorderBrush="#323232"
                BorderThickness="0,0,0,1">
                <Grid x:Name="TitleBarRoot" ColumnSpacing="14" MinHeight="64">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                        <TextBlock
                            x:Name="WindowTitleText"
                            FontSize="24"
                            FontWeight="SemiBold"
                            Foreground="#F2F2F2"
                            Text="ZAVOD" />
                        <TextBlock
                            x:Name="WindowStatusText"
                            FontSize="13"
                            Foreground="#CFCFCF"
                            TextWrapping="Wrap"
                            Text="Recovery mode active." />
                    </StackPanel>

                    <Button
                        x:Name="ProjectsBackButton"
                        Grid.Column="0"
                        Width="40"
                        Height="40"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Click="ProjectsBackButton_Click"
                        Content="←"
                        Visibility="Collapsed" />

                    <Border
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        Padding="6"
                        Background="#262626"
                        BorderBrush="#3A3A3A"
                        BorderThickness="1"
                        CornerRadius="999">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Button x:Name="ChatsModeButton" MinWidth="110" Click="ChatsModeButton_Click" Content="Chats" />
                            <Button x:Name="ProjectsModeButton" MinWidth="110" Click="ProjectsModeButton_Click" Content="Projects" />
                        </StackPanel>
                    </Border>

                    <Button
                        x:Name="RefreshButton"
                        Grid.Column="3"
                        VerticalAlignment="Center"
                        Click="RefreshButton_Click"
                        Content="Refresh" />
                </Grid>
            </Border>

            <Border
                x:Name="ChatsModeRoot"
                Grid.Row="1"
                Margin="18"
                Padding="28"
                Background="#F5F1EA"
                BorderBrush="#D6CCBF"
                BorderThickness="1"
                CornerRadius="20"
                Visibility="Collapsed">
                <Grid RowSpacing="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Spacing="8">
                        <TextBlock
                            Text="Chats"
                            FontFamily="{StaticResource Ui.FontFamily.Chats.SemiBold}"
                            FontSize="30"
                            Foreground="{StaticResource Ui.Chat.TextPrimaryBrush}" />
                        <TextBlock
                            x:Name="ChatsSummaryText"
                            FontFamily="{StaticResource Ui.FontFamily.Chats.Regular}"
                            FontSize="18"
                            Foreground="{StaticResource Ui.Chat.TextSecondaryBrush}"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <Border
                        Grid.Row="1"
                        Padding="18"
                        Background="#FFFDF8"
                        BorderBrush="#D8CEC1"
                        BorderThickness="1"
                        CornerRadius="16">
                        <StackPanel Spacing="10">
                            <TextBlock
                                Text="Free chat mode"
                                FontFamily="{StaticResource Ui.FontFamily.Chats.SemiBold}"
                                FontSize="18"
                                Foreground="{StaticResource Ui.Chat.TextPrimaryBrush}" />
                            <TextBlock
                                x:Name="ChatsPersistenceText"
                                FontFamily="{StaticResource Ui.FontFamily.Chats.Regular}"
                                FontSize="16"
                                Foreground="{StaticResource Ui.Chat.TextSecondaryBrush}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Row="2"
                        Padding="18"
                        Background="#FFFDF8"
                        BorderBrush="#D8CEC1"
                        BorderThickness="1"
                        CornerRadius="16">
                        <TextBlock
                            x:Name="ChatsNotesText"
                            FontFamily="{StaticResource Ui.FontFamily.Chats.Regular}"
                            FontSize="17"
                            Foreground="{StaticResource Ui.Chat.TextPrimaryBrush}"
                            TextWrapping="Wrap" />
                    </Border>
                </Grid>
            </Border>

            <Grid
                x:Name="ProjectsModeRoot"
                Grid.Row="1"
                Margin="18"
                RowSpacing="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border
                    Grid.Row="0"
                    Padding="12"
                    Background="#1D1D1D"
                    BorderBrush="#323232"
                    BorderThickness="1"
                    CornerRadius="16">
                    <StackPanel Spacing="6">
                        <TextBlock x:Name="ProjectsScreenTitleText" Text="Projects" FontSize="24" FontWeight="SemiBold" Foreground="#F2F2F2" />
                        <TextBlock x:Name="ProjectsModeSummaryText" Foreground="#E4E4E4" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Grid Grid.Row="1">
                    <Grid
                        x:Name="ProjectListRoot"
                        RowSpacing="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Project List" FontSize="28" FontWeight="SemiBold" Foreground="#F2F2F2" />
                            <TextBlock x:Name="ProjectListSummaryText" Foreground="#E4E4E4" TextWrapping="Wrap" />
                        </StackPanel>

                        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" HorizontalScrollMode="Enabled" VerticalScrollMode="Disabled">
                            <StackPanel Orientation="Horizontal" Spacing="14">
                                <Border
                                    Width="360"
                                    Padding="18"
                                    Background="#1F1F1F"
                                    BorderBrush="#363636"
                                    BorderThickness="1"
                                    CornerRadius="16">
                                    <StackPanel Spacing="12">
                                        <TextBlock Text="Start Here" FontSize="18" FontWeight="SemiBold" Foreground="#F2F2F2" />
                                        <TextBlock Foreground="#E4E4E4" TextWrapping="Wrap" Text="Projects mode starts here. Import and New Project remain explicit entry actions." />
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Button Content="New project" IsEnabled="False" />
                                            <Button Content="Import" IsEnabled="False" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border
                                    Width="420"
                                    Padding="18"
                                    Background="#1F1F1F"
                                    BorderBrush="#363636"
                                    BorderThickness="1"
                                    CornerRadius="16">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="Current Project" FontSize="18" FontWeight="SemiBold" Foreground="#F2F2F2" />
                                        <TextBlock x:Name="ProjectListCurrentProjectText" Foreground="#CFCFCF" TextWrapping="Wrap" />
                                        <TextBlock x:Name="ProjectListCurrentStageText" Foreground="#E4E4E4" TextWrapping="Wrap" />
                                        <TextBlock x:Name="ProjectListCurrentDetailsText" Foreground="#E4E4E4" TextWrapping="Wrap" />
                                        <Button x:Name="OpenCurrentProjectButton" HorizontalAlignment="Left" Click="OpenCurrentProjectButton_Click" Content="Open project" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <Border
                            Grid.Row="2"
                            Padding="18"
                            Background="#1F1F1F"
                            BorderBrush="#363636"
                            BorderThickness="1"
                            CornerRadius="16">
                            <TextBlock
                                x:Name="ProjectListNotesText"
                                Foreground="#E4E4E4"
                                TextWrapping="Wrap" />
                        </Border>
                    </Grid>

                    <Grid
                        x:Name="ProjectHomeRoot"
                        Visibility="Collapsed"
                        RowSpacing="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Project Home" FontSize="28" FontWeight="SemiBold" Foreground="#F2F2F2" />
                            <TextBlock x:Name="ProjectHomeSummaryText" Foreground="#E4E4E4" TextWrapping="Wrap" />
                        </StackPanel>

                        <Grid Grid.Row="1" ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.1*" />
                                <ColumnDefinition Width="1.2*" />
                            </Grid.ColumnDefinitions>

                            <Border
                                Grid.Column="0"
                                Padding="18"
                                Background="#1F1F1F"
                                BorderBrush="#363636"
                                BorderThickness="1"
                                CornerRadius="16">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Overview" FontSize="18" FontWeight="SemiBold" Foreground="#F2F2F2" />
                                    <TextBlock x:Name="ProjectHomeStatusText" Foreground="#F2F2F2" TextWrapping="Wrap" />
                                    <TextBlock x:Name="ProjectHomeStageText" Foreground="#E4E4E4" TextWrapping="Wrap" />
                                    <TextBlock x:Name="ProjectHomeActivityText" Foreground="#E4E4E4" TextWrapping="Wrap" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button x:Name="OpenProjectHtmlButton" Click="OpenProjectHtmlButton_Click" Content="Open HTML" />
                                        <Button x:Name="OpenProjectHomeDocumentButton" Click="OpenProjectDocumentButton_Click" Content="Open project doc" />
                                        <Button x:Name="OpenWorkCycleButton" Click="OpenWorkCycleButton_Click" Content="Open work cycle" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border
                                Grid.Column="1"
                                Padding="18"
                                Background="#1F1F1F"
                                BorderBrush="#363636"
                                BorderThickness="1"
                                CornerRadius="16">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Materials" FontSize="18" FontWeight="SemiBold" Foreground="#F2F2F2" />
                                    <TextBlock x:Name="ProjectHomeMaterialsText" Foreground="#F2F2F2" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border
                            Grid.Row="2"
                            Padding="18"
                            Background="#1F1F1F"
                            BorderBrush="#363636"
                            BorderThickness="1"
                            CornerRadius="16">
                            <TextBlock
                                x:Name="ProjectHomeNotesText"
                                Foreground="#E4E4E4"
                                TextWrapping="Wrap" />
                        </Border>
                    </Grid>

                    <Grid
                        x:Name="ProjectWorkCycleRoot"
                        Visibility="Collapsed"
                        ColumnSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="WorkCycleChatColumn" Width="1.35*" />
                            <ColumnDefinition x:Name="WorkCycleExecutionColumn" Width="1*" />
                            <ColumnDefinition x:Name="WorkCycleResultColumn" Width="1*" />
                        </Grid.ColumnDefinitions>

                        <Border
                            x:Name="ProjectInteractionSurface"
                            Grid.Column="0"
                            Padding="20"
                            Background="#232323"
                            BorderBrush="#3A3A3A"
                            BorderThickness="1"
                            CornerRadius="16">
                            <Grid RowSpacing="14">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Spacing="6">
                                    <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="#F2F2F2" Text="Interaction Surface" />
                                    <TextBlock x:Name="WorkCycleChatSurfaceStateText" Foreground="#BEBEBE" TextWrapping="Wrap" />
                                    <TextBlock x:Name="WorkCyclePhaseText" Foreground="#F2F2F2" TextWrapping="Wrap" />
                                    <TextBlock x:Name="WorkCycleSummaryText" Foreground="#E4E4E4" TextWrapping="Wrap" />
                                    <StackPanel x:Name="WorkCycleFocusBar" Orientation="Horizontal" Spacing="8">
                                        <Button x:Name="WorkCycleFocusAutoButton" Click="WorkCycleFocusAutoButton_Click" Content="Auto" />
                                        <Button x:Name="WorkCycleFocusChatButton" Click="WorkCycleFocusChatButton_Click" Content="Chat" />
                                        <Button x:Name="WorkCycleFocusExecutionButton" Click="WorkCycleFocusExecutionButton_Click" Content="Execution" />
                                        <Button x:Name="WorkCycleFocusResultButton" Click="WorkCycleFocusResultButton_Click" Content="Result" />
                                    </StackPanel>
                                </StackPanel>

                                <Border
                                    Grid.Row="1"
                                    Padding="14"
                                    Background="#292929"
                                    BorderBrush="#3A3A3A"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                    <StackPanel Spacing="8">
                                        <TextBlock FontSize="13" Foreground="#9A9A9A" Text="Project" />
                                        <TextBlock x:Name="ProjectNameText" FontSize="18" FontWeight="SemiBold" Foreground="#F2F2F2" Text="-" />
                                        <TextBlock FontSize="13" Foreground="#9A9A9A" Text="Project root" />
                                        <TextBlock x:Name="ProjectRootText" FontFamily="Consolas" FontSize="13" Foreground="#DCDCDC" TextWrapping="Wrap" Text="-" />
                                    </StackPanel>
                                </Border>

                                <Border
                                    Grid.Row="2"
                                    Padding="14"
                                    Background="#292929"
                                    BorderBrush="#3A3A3A"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                    <StackPanel Spacing="8">
                                        <TextBlock FontSize="13" Foreground="#9A9A9A" Text="State" />
                                        <TextBlock x:Name="EntryStateText" Foreground="#F2F2F2" Text="-" />
                                        <TextBlock x:Name="StorageStateText" Foreground="#D0D0D0" TextWrapping="Wrap" Text="-" />
                                        <TextBlock x:Name="ActiveShiftText" FontFamily="Consolas" Foreground="#F2F2F2" Text="-" />
                                        <TextBlock x:Name="ActiveTaskText" FontFamily="Consolas" Foreground="#F2F2F2" Text="-" />
                                    </StackPanel>
                                </Border>

                                <Border
                                    Grid.Row="3"
                                    Padding="14"
                                    Background="#1F1F1F"
                                    BorderBrush="#353535"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                    <StackPanel Spacing="8">
                                        <TextBlock x:Name="WorkCycleChatSummaryTitleText" FontSize="16" FontWeight="SemiBold" Foreground="#F2F2F2" />
                                        <TextBlock x:Name="WorkCycleChatSummaryText" Foreground="#E4E4E4" TextWrapping="Wrap" />
                                        <TextBlock x:Name="WorkCycleChatSummaryNoteText" Foreground="#BEBEBE" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Border
                                    Grid.Row="4"
                                    Padding="12"
                                    Background="#292929"
                                    BorderBrush="#3A3A3A"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                    <StackPanel Spacing="10">
                                        <TextBlock FontSize="13" Foreground="#9A9A9A" Text="Recovery notes" />
                                        <TextBlock
                                            x:Name="InteractionNotesText"
                                            Foreground="#C8C8C8"
                                            TextWrapping="Wrap"
                                            Text="Discussion UI and composer remain intentionally disconnected until the owner path is re-proven." />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <Border
                            x:Name="ProjectExecutionSurface"
                            Grid.Column="1"
                            Padding="20"
                            Background="#232323"
                            BorderBrush="#3A3A3A"
                            BorderThickness="1"
                            CornerRadius="16">
                            <Grid RowSpacing="14">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Spacing="6">
                                    <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="#F2F2F2" Text="Execution Surface" />
                                    <TextBlock x:Name="WorkCycleExecutionSurfaceStateText" Foreground="#BEBEBE" TextWrapping="Wrap" />
                                    <TextBlock x:Name="WorkCycleExecutionSummaryText" Foreground="#F2F2F2" TextWrapping="Wrap" />
                                </StackPanel>

                                <Border
                                    Grid.Row="1"
                                    Padding="14"
                                    Background="#292929"
                                    BorderBrush="#3A3A3A"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                    <StackPanel Spacing="8">
                                        <TextBlock FontSize="13" Foreground="#9A9A9A" Text="Execution state" />
                                        <TextBlock x:Name="ExecutionStateText" FontSize="18" FontWeight="SemiBold" Foreground="#F2F2F2" Text="Recovery hold" />
                                        <TextBlock x:Name="ExecutionDetailText" Foreground="#C8C8C8" TextWrapping="Wrap" Text="This surface is reserved and visible again, but no live execution controls are wired back yet." />
                                    </StackPanel>
                                </Border>

                                <Border
                                    Grid.Row="2"
                                    Padding="14"
                                    Background="#292929"
                                    BorderBrush="#3A3A3A"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                    <StackPanel Spacing="10">
                                        <TextBlock FontSize="13" Foreground="#9A9A9A" Text="Available evidence" />
                                        <TextBlock x:Name="DocumentStageText" Foreground="#F2F2F2" Text="-" TextWrapping="Wrap" />
                                        <TextBlock x:Name="ProjectDocumentPathText" FontFamily="Consolas" FontSize="13" Foreground="#B8B8B8" TextWrapping="Wrap" Text="-" />
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <Button x:Name="OpenProjectDocumentButton" Click="OpenProjectDocumentButton_Click" Content="Open project doc" />
                                            <Button x:Name="OpenCapsuleDocumentButton" Click="OpenCapsuleDocumentButton_Click" Content="Open capsule doc" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <Border
                            x:Name="ProjectResultSurface"
                            Grid.Column="2"
                            Padding="20"
                            Background="#232323"
                            BorderBrush="#3A3A3A"
                            BorderThickness="1"
                            CornerRadius="16">
                            <Grid RowSpacing="14">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Spacing="6">
                                    <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="#F2F2F2" Text="Result Surface" />
                                    <TextBlock x:Name="WorkCycleResultSurfaceStateText" Foreground="#BEBEBE" TextWrapping="Wrap" />
                                    <TextBlock x:Name="WorkCycleResultSummaryText" Foreground="#F2F2F2" TextWrapping="Wrap" />
                                </StackPanel>

                                <Border
                                    Grid.Row="1"
                                    Padding="14"
                                    Background="#292929"
                                    BorderBrush="#3A3A3A"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                    <StackPanel Spacing="8">
                                        <TextBlock FontSize="13" Foreground="#9A9A9A" Text="Result state" />
                                        <TextBlock x:Name="ResultStateText" FontSize="18" FontWeight="SemiBold" Foreground="#F2F2F2" Text="No result loaded" />
                                        <TextBlock x:Name="ResultDetailText" Foreground="#C8C8C8" TextWrapping="Wrap" Text="Result lifecycle stays disconnected until discussion and execution layers are safely restored." />
                                    </StackPanel>
                                </Border>

                                <Border
                                    Grid.Row="2"
                                    Padding="14"
                                    Background="#292929"
                                    BorderBrush="#3A3A3A"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                    <StackPanel Spacing="10">
                                        <TextBlock FontSize="13" Foreground="#9A9A9A" Text="What was intentionally withheld" />
                                        <TextBlock
                                            x:Name="ResultNotesText"
                                            Foreground="#C8C8C8"
                                            TextWrapping="Wrap"
                                            Text="Chat timeline, execution controls, QC/result actions, and the new UI flow remain off until each layer is reintroduced under verification." />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
