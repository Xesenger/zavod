<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="zavod.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conversation="using:zavod.UI.Rendering.Conversation"
    xmlns:chats="using:zavod.UI.Modes.Chats"
    xmlns:shell="using:zavod.UI.Shell.Header"
    xmlns:projects="using:zavod.UI.Modes.Projects"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="WindowRoot" Background="#171717">
        <Grid RowSpacing="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border
                x:Name="HeaderBorder"
                Grid.Row="0"
                Margin="18,18,18,0"
                Padding="14,12,14,12"
                Background="#1D1D1D"
                BorderBrush="#323232"
                BorderThickness="0,0,0,1">
                <Grid x:Name="TitleBarRoot" ColumnSpacing="14" MinHeight="64">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="64" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="64" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                        <TextBlock
                            x:Name="WindowTitleText"
                            FontSize="24"
                            FontWeight="SemiBold"
                            Foreground="#F2F2F2"
                            Text="ZAVOD" />
                        <TextBlock
                            x:Name="WindowStatusText"
                            FontSize="13"
                            Foreground="#CFCFCF"
                            TextWrapping="Wrap"
                            Text="Recovery mode active." />
                    </StackPanel>

                    <Button
                        x:Name="ProjectsBackButton"
                        Grid.Column="0"
                        Width="40"
                        Height="40"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Click="ProjectsBackButton_Click"
                        Content="←"
                        Visibility="Collapsed" />

                    <shell:ModeSwitchView
                        x:Name="ModeSwitchView"
                        Grid.Column="2"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" />

                    <Button
                        x:Name="RefreshButton"
                        Grid.Column="4"
                        Width="40"
                        Height="40"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Click="RefreshButton_Click"
                        Content="Refresh" />
                </Grid>
            </Border>

