<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="zavod.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <x:String x:Key="Ui.WindowTitle">ZAVOD</x:String>
        <FontFamily x:Key="Ui.FontFamily.Chats.Regular">ms-appx:///Assets/Fonts/Lora-Regular.ttf#Lora</FontFamily>
        <FontFamily x:Key="Ui.FontFamily.Chats.SemiBold">ms-appx:///Assets/Fonts/Lora-SemiBold.ttf#Lora</FontFamily>
        <FontFamily x:Key="Ui.FontFamily.Projects.Regular">ms-appx:///Assets/Fonts/IBMPlexSans-Regular.otf#IBM Plex Sans</FontFamily>
        <FontFamily x:Key="Ui.FontFamily.Projects.SemiBold">ms-appx:///Assets/Fonts/IBMPlexSans-SemiBold.otf#IBM Plex Sans</FontFamily>

        <x:Double x:Key="Ui.Typography.Chats.FontSize">19</x:Double>
        <x:Double x:Key="Ui.Typography.Chats.LineHeight">31</x:Double>
        <x:Double x:Key="Ui.Typography.Projects.FontSize">14</x:Double>
        <x:Double x:Key="Ui.Typography.Projects.LineHeight">22</x:Double>

        <SolidColorBrush x:Key="Ui.AccentSoftBrush" Color="#F2E6DA" />
        <SolidColorBrush x:Key="Ui.AccentLineBrush" Color="#C27A49" />
        <SolidColorBrush x:Key="Ui.SurfaceSubtleBrush" Color="#F4F0E9" />
        <SolidColorBrush x:Key="Ui.BorderQuietBrush" Color="#D7CDBE" />
        <SolidColorBrush x:Key="Ui.BorderSubtleBrush" Color="#D8D1C8" />
        <SolidColorBrush x:Key="Ui.SurfaceErrorBrush" Color="#3B2323" />
        <SolidColorBrush x:Key="Ui.ErrorBorderBrush" Color="#8A4545" />

        <SolidColorBrush x:Key="Ui.Chat.TextPrimaryBrush" Color="#2A241F" />
        <SolidColorBrush x:Key="Ui.Chat.TextSecondaryBrush" Color="#6D6258" />
        <SolidColorBrush x:Key="Ui.Chat.SurfaceSubtleBrush" Color="#F7F1E8" />
        <SolidColorBrush x:Key="Ui.Chat.SurfaceQuoteBrush" Color="#F2ECE4" />
        <SolidColorBrush x:Key="Ui.Chat.SurfaceCodeBrush" Color="#EEE7DE" />
        <SolidColorBrush x:Key="Ui.Chat.BorderQuietBrush" Color="#D8CEC1" />
        <SolidColorBrush x:Key="Ui.Chat.AccentLineBrush" Color="#B9774B" />
        <SolidColorBrush x:Key="Ui.Chat.AccentFillBrush" Color="#F0DFCF" />
        <SolidColorBrush x:Key="Ui.Chat.AccentForegroundBrush" Color="#6A3F21" />
        <SolidColorBrush x:Key="Ui.Chat.UserBubbleBackgroundBrush" Color="#E7D4C1" />
        <SolidColorBrush x:Key="Ui.Chat.UserBubbleBorderBrush" Color="#C28958" />
        <SolidColorBrush x:Key="Ui.Chat.UserBubbleTextBrush" Color="#2A1E16" />

        <SolidColorBrush x:Key="Ui.Project.TextPrimaryBrush" Color="#F2F2F2" />
        <SolidColorBrush x:Key="Ui.Project.TextSecondaryBrush" Color="#A6A6A6" />
        <SolidColorBrush x:Key="Ui.Project.SurfaceSubtleBrush" Color="#232323" />
        <SolidColorBrush x:Key="Ui.Project.SurfaceQuoteBrush" Color="#262626" />
        <SolidColorBrush x:Key="Ui.Project.SurfaceCodeBrush" Color="#1E1E1E" />
        <SolidColorBrush x:Key="Ui.Project.BorderQuietBrush" Color="#3A3A3A" />
        <SolidColorBrush x:Key="Ui.Project.AccentLineBrush" Color="#6A8AC9" />
        <SolidColorBrush x:Key="Ui.Project.AccentFillBrush" Color="#1D2535" />
        <SolidColorBrush x:Key="Ui.Project.AccentForegroundBrush" Color="#C8D5F3" />
        <SolidColorBrush x:Key="Ui.Project.UserBubbleBackgroundBrush" Color="#2F394B" />
        <SolidColorBrush x:Key="Ui.Project.UserBubbleBorderBrush" Color="#526786" />
        <SolidColorBrush x:Key="Ui.Project.UserBubbleTextBrush" Color="#F5F7FA" />

        <SolidColorBrush x:Key="CardStrokeColorDefaultBrush" Color="#3A3A3A" />

        <Style x:Key="AccentButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="10,4,10,4" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="{StaticResource Ui.Project.AccentFillBrush}" />
            <Setter Property="Foreground" Value="{StaticResource Ui.Project.AccentForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource Ui.Project.AccentLineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontFamily" Value="{StaticResource Ui.FontFamily.Projects.Regular}" />
            <Setter Property="FontSize" Value="12" />
        </Style>
    </Application.Resources>
</Application>
